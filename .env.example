# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=
# Optional: text + vision model for site audit, ad brief analysis, chat fallback (default: gemini-2.0-flash)
GEMINI_CHAT_MODEL=
# Optional override for Ad Brief image generation (default: gemini-2.5-flash-image)
GEMINI_IMAGE_MODEL=
VITE_GEMINI_API_KEY=
STITCH_API_KEY=
STITCH_PROJECT_ID=
RESEND_API_KEY=
PORT=8081

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_PSI_API_KEY: PageSpeed Insights API key — enables real Lighthouse mobile scores in /api/analyze.
# Create: https://developers.google.com/speed/docs/insights/v5/get-started
# In Google Cloud: enable "PageSpeed Insights API" for the project. Key must allow that API (API restrictions).
# For Cloud Run / Node: use Application restrictions = None or IP addresses — NOT "HTTP referrers only".
# If PSI is unavailable (quota, keys, blocking), the server automatically falls back to direct HTTP crawl:
# time-to-first-byte plus parsing title, meta description, viewport, JSON-LD — labeled in response psiMeta.
GOOGLE_PSI_API_KEY=

# KIE_API_KEY: Primary AI for site audit + Ad Brief (GPT-4o chat/vision + 4o Image when set).
KIE_API_KEY=
# Optional: Kie chat model (default gpt-4o). Kie file upload host for Ad Brief creatives.
KIE_CHAT_MODEL=gpt-4o
KIE_UPLOAD_BASE=https://kieai.redpandaai.co

# AGENCY OS (adhelloleadsos) SYNC
ADHELLO_LEADSOS_URL="https://leads.adhello.ai"
ADHELLO_LEADSOS_API_KEY="adhello_secret_123"
